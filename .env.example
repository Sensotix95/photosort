# Copy this file to .env and fill in the values

# Gemini API key — get a free key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe — get keys at dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_random_64_char_hex_string

# URL where the frontend is served (no trailing slash)
FRONTEND_URL=http://localhost:3000

PORT=3000
